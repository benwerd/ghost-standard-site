# Copy to .dev.vars (gitignored) and fill in. In production, set every one
# of these with `npx wrangler secret put <NAME>` — nothing is committed.

# Secrets
GHOST_WEBHOOK_SECRET=replace-with-a-long-random-string
ATPROTO_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GHOST_CONTENT_API_KEY=replace-me

# Identity and site configuration
ATPROTO_HANDLE=your-handle.example.com
ATPROTO_DID=did:plc:replaceme
ATPROTO_PDS_URL=https://your-pds.example.com
GHOST_URL=https://yourblog.example.com

# Optional: override the publication name pulled from Ghost settings
# PUBLICATION_NAME=
